# LLM API 配置
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-api-key
LLM_MODEL=deepseek-chat

# 对话专用快速模型 (可选, 默认使用 LLM_MODEL)
# 对话需要低延迟, 推荐使用快速模型如 deepseek-v4-flash
# LLM_DIALOGUE_MODEL=deepseek-v4-flash

# 世界文件路径 (默认 worlds/small_town.yaml)
# 生成新世界: npm run world:generate kingdom "你的世界种子"
# WORLD_FILE=worlds/generated_kingdom.yaml
